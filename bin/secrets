#!/usr/bin/env bash
# bin/secrets — seed/rotate hal's secrets in the shared app-config blob.
#
#   bin/secrets
#
# Runs entirely on the workstation against the prod account (control-
# plane admin action, like `terraform apply`) — no ssh, no box. It does
# a NON-DESTRUCTIVE read-modify-write of ONLY this node's key in the
# single shared SecureString /metaspot/prod/app-config: every other
# app's key in the blob is preserved untouched. (The shared-blob
# tradeoff is called out in metaspot/AGENTS.md — hence RMW, never
# blind-overwrite.)
#
# Secret values come from ~/.secrets/GOOGLE_* (same source as
# app-root/.envrc); any can be overridden by an env var of the same
# name. The non-secret HAL_RESOURCE_IDENTIFIER is NOT stored here — the
# launcher derives it from METASPOT_FQDN.
set -euo pipefail

NODE="${HAL_NODE:-hal}"
PARAM="/metaspot/prod/app-config"
AWS_PROFILE_NAME="${AWS_PROFILE:-prod}"
AWS_REGION_NAME="${AWS_REGION:-us-east-2}"
SECRETS_DIR="${SECRETS_DIR:-$HOME/.secrets}"

aws_() { aws --profile "$AWS_PROFILE_NAME" --region "$AWS_REGION_NAME" "$@"; }

# Resolve a secret: prefer an already-exported env var, else the file
# under ~/.secrets. Trims surrounding whitespace/newline.
resolve() {
  local name="$1" val
  if [ -n "${!name:-}" ]; then
    val="${!name}"
  elif [ -r "$SECRETS_DIR/$name" ]; then
    val="$(cat "$SECRETS_DIR/$name")"
  else
    echo "secrets: $name not set and $SECRETS_DIR/$name not readable" >&2
    exit 1
  fi
  printf '%s' "$val" | tr -d '[:space:]'
}

CID="$(resolve GOOGLE_CLIENT_ID)"
CSEC="$(resolve GOOGLE_CLIENT_SECRET)"
DOM="$(resolve GOOGLE_WORKSPACE_DOMAIN)"

# Same fail-fast shape checks the launcher applies, but here — before
# anything is written.
[ -n "$CID" ]  || { echo "secrets: GOOGLE_CLIENT_ID is empty" >&2; exit 1; }
[ -n "$CSEC" ] || { echo "secrets: GOOGLE_CLIENT_SECRET is empty" >&2; exit 1; }
[ -n "$DOM" ]  || { echo "secrets: GOOGLE_WORKSPACE_DOMAIN is empty" >&2; exit 1; }
case "$CID" in
  *.apps.googleusercontent.com) ;;
  *) echo "secrets: GOOGLE_CLIENT_ID does not look like a Google OAuth client id" >&2; exit 1 ;;
esac
case "$DOM" in
  *.*) ;;
  *) echo "secrets: GOOGLE_WORKSPACE_DOMAIN does not look like a domain" >&2; exit 1 ;;
esac

# Read the current blob. The Terraform-created parameter starts with a
# non-JSON placeholder; treat anything that is not valid JSON as an
# empty object (we are the first writer).
EXISTING="$(aws_ ssm get-parameter --name "$PARAM" --with-decryption \
  --query Parameter.Value --output text 2>/dev/null || true)"
if BASE="$(printf '%s' "$EXISTING" | jq -e . 2>/dev/null)"; then :; else BASE='{}'; fi

# Non-destructive: set only .<node>, preserve every sibling key.
NEW="$(printf '%s' "$BASE" | jq \
  --arg n "$NODE" --arg cid "$CID" --arg csec "$CSEC" --arg dom "$DOM" \
  '.[$n] = {GOOGLE_CLIENT_ID:$cid, GOOGLE_CLIENT_SECRET:$csec, GOOGLE_WORKSPACE_DOMAIN:$dom}')"

mask() { local s="$1"; [ "${#s}" -le 8 ] && { echo '****'; return; }; \
         printf '%s…%s\n' "${s:0:4}" "${s: -4}"; }
SIBLINGS="$(printf '%s' "$BASE" | jq -r --arg n "$NODE" \
  'keys - [$n] | join(", ") | if . == "" then "(none)" else . end')"

echo
echo "  SECRETS — write key .$NODE into $PARAM"
echo "    profile/region : $AWS_PROFILE_NAME / $AWS_REGION_NAME"
echo "    GOOGLE_CLIENT_ID        : $(mask "$CID")"
echo "    GOOGLE_CLIENT_SECRET    : $(mask "$CSEC")"
echo "    GOOGLE_WORKSPACE_DOMAIN : $DOM"
echo "    sibling keys preserved  : $SIBLINGS"
echo
printf '  Type "yes" to write: '
read -r ANS
if [ "$ANS" != "yes" ]; then
  echo "secrets: aborted (nothing written)."
  exit 1
fi

# Pass the value via a mode-0600 temp file (file://), never on the
# command line — argv is visible to other processes via ps.
TMP="$(mktemp)"; chmod 600 "$TMP"
trap 'rm -f "$TMP"' EXIT
printf '%s' "$NEW" > "$TMP"
aws_ ssm put-parameter --name "$PARAM" \
  --type SecureString --overwrite --value "file://$TMP" >/dev/null

echo "secrets: .$NODE written to $PARAM. Apply with: bin/deploy (or systemctl restart hal)."
