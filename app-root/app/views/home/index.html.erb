<%# R-QY5R-PYDH: render the current count as a number in plain HTML. %>
<%# R-TK21-6AGY: usable with JavaScript disabled — count is server-rendered. %>

<%# R-YLFY-6A8V / R-NJUD-EFQ5: top-bar row above the banner card,
    right-anchored. Carries the auth area as pill-style affordances in
    both states. Signed-out: a single `Sign in` pill linking to /login.
    Signed-in: the visitor's email as inert, non-interactive text (a
    label, not a control) followed by a separate, explicitly labeled
    `Sign out` pill linking to /logout. Placement is load-bearing —
    must sit above and to the right of the banner card. %>
<div id="top-bar" class="top-bar">
  <section id="web-session" class="web-session">
    <% if @web_email %>
      <span id="web-email" class="auth-pill auth-pill--signed-in auth-pill__email"><%= @web_email %></span>
      <a href="/logout" id="web-logout" class="auth-pill auth-pill--signout">Sign out</a>
    <% else %>
      <a href="/login" id="web-login" class="auth-pill auth-pill--signed-out">Sign in</a>
    <% end %>
  </section>
</div>

<%# R-JXMD-JMLM / R-K7QI-9YW4: banner card with lens dot, tag, HAL title,
    subtitle row, re-roll. R-MG6P-TA7C supplies the subtitle bank that
    @subtitle is drawn from; the bank is also embedded as JSON below so
    the re-roll control can sample a fresh entry client-side without a
    GET /. %>
<section class="banner">
  <span class="lens" aria-hidden="true"></span>
  <span class="tag">MCP · demo</span>
  <h1 class="title">HAL</h1>
  <div class="subtitle-row">
    <span class="subtitle" id="subtitle"><%= @subtitle %></span>
    <button type="button" class="refresh" id="reroll" aria-label="New subtitle">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="23 4 23 10 17 10"></polyline>
        <polyline points="1 20 1 14 7 14"></polyline>
        <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10"></path>
        <path d="M20.49 15a9 9 0 0 1-14.85 3.36L1 14"></path>
      </svg>
    </button>
  </div>
  <%# R-K7QI-9YW4 / R-MG6P-TA7C: subtitle bank embedded for client-side
      sampling. Activating #reroll picks a fresh entry from this list
      and cross-fades it into #subtitle — no GET /, no navigation. %>
  <script type="application/json" id="subtitle-bank"><%== HomeController::EXPANSIONS.to_json %></script>
</section>

<%# R-K7QI-9YW4: re-roll behavior. On activation, sample a new entry
    from the embedded bank uniformly at random and cross-fade it into
    #subtitle over ~220ms. No GET / is issued; scroll, focus, the open
    SSE connection (R-K65O-80SH), and the URL bar are preserved. Under
    prefers-reduced-motion: reduce the swap is instant (the .subtitle
    transition is collapsed by R-9VH6-C2KA's reduced-motion block). %>
<script>
(function () {
  var btn = document.getElementById("reroll");
  var sub = document.getElementById("subtitle");
  var bankEl = document.getElementById("subtitle-bank");
  if (!btn || !sub || !bankEl) return;
  var bank;
  try { bank = JSON.parse(bankEl.textContent); } catch (_e) { return; }
  if (!Array.isArray(bank) || bank.length === 0) return;
  btn.addEventListener("click", function (e) {
    e.preventDefault();
    var next = bank[Math.floor(Math.random() * bank.length)];
    sub.style.opacity = "0";
    setTimeout(function () {
      sub.textContent = next;
      sub.style.opacity = "1";
    }, 220);
  });
})();
</script>

<%# R-YJ05-EQRH: counter card below the banner. Contains label, value,
    decrement/increment buttons, and a session-aware hint line. When the
    visitor has an active web session (R-YLFY-6A8V), the buttons submit
    standard HTML forms to /counter/decrement and /counter/increment;
    the endpoints reply with a 303 redirect to / so the page reloads
    with the new value when JavaScript is disabled (R-TK21-6AGY). When
    no session is active, the buttons render visibly disabled. %>
<%# R-NIMH-0NZG: counter card with +/- mutation behavior. The buttons
    POST to /counter/increment and /counter/decrement under the
    visitor's web-session cookie (R-OCH3-8FQ8); on success the new
    value reflects on the page via the live channel (R-K65O-80SH).
    With JS disabled (R-TK21-6AGY) the standard form submission yields
    a 303 redirect to / and the page reloads with the new value. %>
<section class="counter-card" id="counter-card">
  <%# R-YJ05-EQRH: ≥640px row — label/value on the left, −/+ grouped on
      the right of the same row. <640px collapses to a column. %>
  <div class="counter-row">
    <div class="counter-main">
      <p class="counter-label">CURRENT COUNT</p>
      <%# R-K4XR-U91S: aria-live="polite" wrapper so live-channel updates
          (R-K65O-80SH) are announced to assistive tech. %>
      <span aria-live="polite"><span class="counter-value" id="count"><%= @count %></span></span>
    </div>
    <div class="counter-controls">
      <% if @web_email %>
        <%# R-OCH3-8FQ8: the web-session cookie alone authenticates the
            POST; no bearer token needed. %>
        <form action="/counter/decrement" method="post" class="counter-form">
          <input type="hidden" name="from" value="index">
          <button type="submit" class="counter-button" aria-label="Decrement">−</button>
        </form>
      <% else %>
        <button type="button" class="counter-button" aria-label="Decrement" disabled>−</button>
      <% end %>
      <% if @web_email %>
        <form action="/counter/increment" method="post" class="counter-form">
          <input type="hidden" name="from" value="index">
          <button type="submit" class="counter-button" aria-label="Increment">+</button>
        </form>
      <% else %>
        <button type="button" class="counter-button" aria-label="Increment" disabled>+</button>
      <% end %>
    </div>
  </div>
  <%# R-NIMH-0NZG: brief inline rejection slot. With JS, a `−` click
      against a zero counter (R-F5X4-XI2F) flips this visible for
      ~1.4s; the displayed value stays unchanged. %>
  <p class="counter-reject" id="counter-reject" role="status" aria-live="polite" hidden>Counter is at zero.</p>
  <p class="counter-hint">
    <% if @web_email %>
      Signed in. The MCP server can read &amp; mutate this counter on your behalf.
    <% else %>
      Sign in to manipulate the counter from the browser. The MCP server can read &amp; mutate it for any signed-in user.
    <% end %>
  </p>
</section>

<%# R-NIMH-0NZG: JS-enabled async path for the +/- buttons. Intercepts
    submission of the counter forms and POSTs via fetch so there is no
    full-page reload; the new value arrives via the live-update channel
    (R-K65O-80SH). On a `−` against a zero counter the endpoint returns
    409 (R-F5X4-XI2F / R-H3FE-QFC0) — we briefly reveal #counter-reject
    and leave the displayed value alone. Session-cookie auth alone
    authenticates the POST per R-OCH3-8FQ8; no bearer token is needed.
    With JS disabled the forms degrade to standard submission. %>
<script>
(function () {
  var forms = document.querySelectorAll(".counter-form");
  if (!forms.length) return;
  function showRejection() {
    var el = document.getElementById("counter-reject");
    if (!el) return;
    el.hidden = false;
    el.classList.add("counter-reject--visible");
    setTimeout(function () {
      el.hidden = true;
      el.classList.remove("counter-reject--visible");
    }, 1400);
  }
  forms.forEach(function (form) {
    form.addEventListener("submit", function (e) {
      e.preventDefault();
      var url = form.getAttribute("action");
      fetch(url, {
        method: "POST",
        headers: { "Accept": "application/json" },
        credentials: "same-origin"
      }).then(function (r) {
        if (r.status === 409) { showRejection(); }
      }).catch(function () {});
    });
  });
})();
</script>

<%# R-K65O-80SH: SSE live-update bootstrap. The page works fine without
    JS (R-TK21-6AGY) — the count is server-rendered above. With JS enabled
    we open a no-auth EventSource to /counter/stream and update #count in
    place on every change, with the R-YJ05-EQRH flash + delta animation
    suppressed when prefers-reduced-motion is set (R-K4XR-U91S). %>
<script>
(function () {
  if (typeof EventSource === "undefined") return;
  var countEl = document.getElementById("count");
  if (!countEl) return;

  var es = new EventSource("/counter/stream");
  var lastShown = parseInt(countEl.textContent, 10);
  if (isNaN(lastShown)) lastShown = null;

  function reduceMotion() {
    return window.matchMedia &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  }

  function flashAndDelta(prev, next) {
    if (prev === null || prev === next) return;
    if (reduceMotion()) return;
    countEl.classList.add("counter-flash");
    setTimeout(function () { countEl.classList.remove("counter-flash"); }, 600);

    var delta = document.createElement("span");
    delta.className = "counter-delta";
    delta.textContent = (next > prev ? "+" : "−") + Math.abs(next - prev);
    countEl.parentNode.appendChild(delta);
    setTimeout(function () {
      if (delta.parentNode) delta.parentNode.removeChild(delta);
    }, 900);
  }

  es.onmessage = function (event) {
    try {
      var msg = JSON.parse(event.data);
      if (typeof msg.value !== "number") return;
      var prev = lastShown;
      countEl.textContent = String(msg.value);
      flashAndDelta(prev, msg.value);
      lastShown = msg.value;
    } catch (_e) { /* ignore malformed events */ }
  };
})();
</script>

<%# R-BZQY-DN3B: copy-pasteable MCP client configuration. %>
<%# R-VVRG-W2G2: no Google details, no client credentials, no internal paths beyond base URL. %>
<%# R-YHS9-0Z0S: instructions area — header (h2 + right-aligned muted subhead),
    two stacked section cards (01 Claude Code / 02 Claude Desktop) with
    off-white card fills, numeric badge, title, and right-aligned kind
    description; dark-background code blocks with semantic token coloring,
    each wrapped in a .code-block carrying a visible `copy` overlay button
    that copies its <pre> plaintext via navigator.clipboard.writeText (with
    a textarea + execCommand fallback) and flips to a mint-green `copied`
    label for ~1.4s. With JS disabled (R-TK21-6AGY) the button is inert
    but the code remains selectable. %>
<section id="mcp-config">
  <div class="instructions-head">
    <h2>Connect an MCP client</h2>
    <p class="instructions-subhead">Point a client at <span class="mono"><%= @base_url %>/mcp</span></p>
  </div>

  <%# R-5GQZ-KWCD: Claude Code uses `claude mcp add --transport http …`. %>
  <%# R-JV1V-OF3W: two examples distinguished by --scope (project vs user). %>
  <%# R-9T1D-KJ2W: the two scope examples render as a functional tab
      interface — two role="tab" buttons above one role="tabpanel"
      holding the active scope's snippet. Project is the default active
      tab. Both snippets ship in the rendered HTML; the JS below toggles
      which is shown with no GET / or navigation. Accent-red 2px bottom
      border marks the active trigger. ARIA wired per WAI-ARIA APG. %>
  <article class="section" id="section-claude-code">
    <header class="section-head">
      <span class="num">01</span>
      <h3>Claude Code</h3>
      <span class="desc">CLI · adds a server entry to a scope</span>
    </header>
    <div class="section-body">
      <div class="scope-tabs" role="tablist" aria-label="Claude Code scope">
        <button type="button" role="tab" id="scope-tab-project" class="scope-tab scope-tab--active" aria-selected="true" aria-controls="scope-tabpanel" data-scope="project">Project scope <span class="mono">.mcp.json</span></button>
        <button type="button" role="tab" id="scope-tab-user" class="scope-tab" aria-selected="false" aria-controls="scope-tabpanel" data-scope="user">User scope <span class="mono">~/.claude.json</span></button>
      </div>
      <div id="scope-tabpanel" role="tabpanel" aria-labelledby="scope-tab-project" class="scope-tabpanel">
        <div class="code-block" data-scope="project">
          <pre class="code" id="claude-code-config-project"><code><span class="prompt">$ </span><span class="arg">claude</span> mcp add <span class="flag">--transport</span> http <span class="flag">--scope</span> project hal <span class="url"><%= @base_url %>/mcp</span></code></pre>
          <button type="button" class="copy" data-copy-target="claude-code-config-project" aria-label="Copy code"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg><span class="copy-label">copy</span></button>
        </div>
        <div class="code-block" data-scope="user" hidden>
          <pre class="code" id="claude-code-config-user"><code><span class="prompt">$ </span><span class="arg">claude</span> mcp add <span class="flag">--transport</span> http <span class="flag">--scope</span> user hal <span class="url"><%= @base_url %>/mcp</span></code></pre>
          <button type="button" class="copy" data-copy-target="claude-code-config-user" aria-label="Copy code"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg><span class="copy-label">copy</span></button>
        </div>
      </div>
    </div>
  </article>
  <%# R-9T1D-KJ2W: client-side tab toggle. Clicking the inactive
      trigger swaps which <pre> is visible and re-targets the copy
      button. No fetch, no GET /, no URL change. %>
  <script>
  (function () {
    var tablist = document.querySelector('#section-claude-code [role="tablist"]');
    if (!tablist) return;
    var tabs = tablist.querySelectorAll('[role="tab"]');
    var panel = document.getElementById("scope-tabpanel");
    if (!tabs.length || !panel) return;
    function activate(scope) {
      tabs.forEach(function (t) {
        var on = t.getAttribute("data-scope") === scope;
        t.setAttribute("aria-selected", on ? "true" : "false");
        t.classList.toggle("scope-tab--active", on);
      });
      panel.querySelectorAll(".code-block").forEach(function (cb) {
        cb.hidden = cb.getAttribute("data-scope") !== scope;
      });
      var active = document.getElementById("scope-tab-" + scope);
      if (active) panel.setAttribute("aria-labelledby", active.id);
    }
    tabs.forEach(function (t) {
      t.addEventListener("click", function () { activate(t.getAttribute("data-scope")); });
    });
  })();
  </script>

  <%# R-5GQZ-KWCD: Claude Desktop uses a `mcpServers` block in claude_desktop_config.json. %>
  <article class="section" id="section-claude-desktop">
    <header class="section-head">
      <span class="num">02</span>
      <h3>Claude Desktop</h3>
      <span class="desc">JSON · add to your <span class="mono">claude_desktop_config.json</span></span>
    </header>
    <div class="section-body">
      <div class="code-block">
        <pre class="code" id="claude-desktop-config"><code><span class="punct">{</span>
  <span class="key">"mcpServers"</span><span class="punct">:</span> <span class="punct">{</span>
    <span class="key">"hal"</span><span class="punct">:</span> <span class="punct">{</span>
      <span class="key">"type"</span><span class="punct">:</span> <span class="str">"http"</span><span class="punct">,</span>
      <span class="key">"url"</span><span class="punct">:</span> <span class="str">"<%= @base_url %>/mcp"</span>
    <span class="punct">}</span>
  <span class="punct">}</span>
<span class="punct">}</span></code></pre>
        <button type="button" class="copy" data-copy-target="claude-desktop-config" aria-label="Copy code"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg><span class="copy-label">copy</span></button>
      </div>
    </div>
  </article>
</section>

<%# R-YHS9-0Z0S: copy-button behavior. Uses navigator.clipboard.writeText
    when available; otherwise falls back to a transient textarea +
    document.execCommand('copy'). On success the button flips to a
    mint-green `copied` label for ~1.4s. %>
<script>
(function () {
  var buttons = document.querySelectorAll("#mcp-config .copy");
  if (!buttons.length) return;
  function copyText(text) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      return navigator.clipboard.writeText(text).then(function () { return true; }, function () { return fallback(text); });
    }
    return Promise.resolve(fallback(text));
  }
  function fallback(text) {
    try {
      var ta = document.createElement("textarea");
      ta.value = text;
      ta.setAttribute("readonly", "");
      ta.style.position = "absolute";
      ta.style.left = "-9999px";
      document.body.appendChild(ta);
      ta.select();
      var ok = document.execCommand("copy");
      document.body.removeChild(ta);
      return ok;
    } catch (_e) { return false; }
  }
  buttons.forEach(function (btn) {
    btn.addEventListener("click", function () {
      var id = btn.getAttribute("data-copy-target");
      var pre = id && document.getElementById(id);
      if (!pre) return;
      var label = btn.querySelector(".copy-label");
      // R-9WP2-PUAZ clipboard property: strip leading shell-prompt
      // prefix ("$ " or "> ") so what lands on the clipboard is the
      // executable form of the snippet.
      var payload = pre.textContent.replace(/^[\$>]\s+/, "");
      Promise.resolve(copyText(payload)).then(function (ok) {
        if (!ok) return;
        btn.classList.add("copied");
        if (label) label.textContent = "copied";
        setTimeout(function () {
          btn.classList.remove("copied");
          if (label) label.textContent = "copy";
        }, 1400);
      });
    });
  });
})();
</script>

<%# R-K3PV-GHB3: footer below the instructions area, separated by a top
    border. Left: a decorative green status dot followed by the textual
    phrase "MCP server live" (the text carries the meaning; the listening
    port is deliberately omitted as a deployment-internal detail). Right:
    the literal "v0.1.0· open my pod bay doors" version + flavor line. %>
<footer id="page-footer" style="border-top:1px solid #2a2a2a;display:flex;justify-content:space-between;align-items:center;padding:8px 12px;font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace;font-size:12px;color:#8a8a8a;margin-top:24px">
  <span class="footer-left" style="display:flex;align-items:center;gap:8px">
    <span class="status-dot" aria-hidden="true" style="display:inline-block;width:7px;height:7px;border-radius:50%;background:#3ddc84;box-shadow:0 0 6px rgba(61,220,132,0.7)"></span>
    <span>MCP server live</span>
  </span>
  <span class="footer-right">v0.1.0 · open my pod bay doors</span>
</footer>
