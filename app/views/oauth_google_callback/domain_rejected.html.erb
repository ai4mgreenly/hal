<%# R-5LQM-O89D: Google identity is outside the configured Workspace domain — reject with a clear error message and no token. %>
<h1>Sign-in not allowed</h1>
<p>
  This service is restricted to Google Workspace accounts in
  <strong><%= @allowed_domain.presence || "(no domain configured)" %></strong>.
</p>
<% if @presented_email.present? %>
  <p>
    The Google account
    <strong><%= @presented_email %></strong>
    <% if @presented_domain.present? %>
      belongs to <strong><%= @presented_domain %></strong>,
    <% end %>
    which is not permitted. No access token has been issued.
  </p>
<% else %>
  <p>The Google account presented is not in an allowed domain. No access token has been issued.</p>
<% end %>
