<%# R-QY5R-PYDH: render the current count as a number in plain HTML. %>
<%# R-SY3U-AF4G: no in-page control to mutate the count. %>
<%# R-TK21-6AGY: usable with JavaScript disabled — count is server-rendered. %>
<%# R-HALR-NDM1: H.A.L. banner + server-picked random subtitle. The
    trailing anchor re-requests the index, which re-rolls the
    subtitle server-side. No JavaScript needed. %>
<h1>H.A.L.</h1>
<p class="subtitle">
  <%= @expansion %>
  <a href="/" class="reroll" aria-label="reroll subtitle" title="reroll">&#x21bb;</a>
</p>
<p>Current count: <span id="count"><%= @count %></span></p>

<%# R-BZQY-DN3B: copy-pasteable MCP client configuration. %>
<%# R-VVRG-W2G2: no Google details, no client credentials, no internal paths beyond base URL. %>
<section id="mcp-config">
  <h2>Connect an MCP client</h2>

  <%# R-5GQZ-KWCD: Claude Code uses `claude mcp add --transport http …`. %>
  <h3>Claude Code</h3>
  <pre id="claude-code-config"><code>claude mcp add --transport http hal <%= @base_url %>/mcp</code></pre>

  <%# R-5GQZ-KWCD: Claude Desktop uses a `mcpServers` block in claude_desktop_config.json. %>
  <h3>Claude Desktop</h3>
  <pre id="claude-desktop-config"><code>{
  "mcpServers": {
    "hal": {
      "type": "http",
      "url": "<%= @base_url %>/mcp"
    }
  }
}</code></pre>
</section>
