# Rails — ignore artifacts produced at runtime; keep .keep markers so the
# directory shape survives a fresh checkout.

# Local secrets — config/master.key decrypts config/credentials.yml.enc
# and never belongs in the repo.
/app-root/config/master.key

# Local environment overrides
.env
.env.*
!.env.example

# SQLite databases (R-IPU6-RP6Q persistence is SQLite)
/app-root/storage/*.sqlite3
/app-root/storage/*.sqlite3-*
/app-root/db/*.sqlite3
/app-root/db/*.sqlite3-*

# Logs and tempfiles
/app-root/log/*
!/app-root/log/.keep
/app-root/tmp/*
!/app-root/tmp/.keep
!/app-root/tmp/pids
/app-root/tmp/pids/*
!/app-root/tmp/pids/.keep

# Bundler / RubyGems
/app-root/.bundle
/app-root/vendor/bundle

# Ralph run state
/app-root/.ralph/

# Go build artifacts and local SQLite database. The binary defaults to
# ./hal.DB (uppercase); match either case plus SQLite -wal/-shm/-journal
# sidecar files.
/app-root/hal
/app-root/hal.[dD][bB]
/app-root/hal.[dD][bB]-*

# Local backups
/reqs.bak/

# Editor / OS detritus
.DS_Store
*.swp
*~
.idea/
.vscode/
